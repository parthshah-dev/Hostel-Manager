# Project root gitignore

# Backend / Maven specific ignore rules
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/HELP.md

# Frontend / Node specific ignore rules
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# STS / IDE specific files
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
.idea
*.iws
*.iml
*.ipr
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/
build/
.vscode/

# Logs and OS files
*.log
.DS_Store
Thumbs.db
